{
  "id": "profile_pill_pager_item",
  "type": "profile_pill",
  "content_key_map": {
    "kind":         "brand.kind",
    "avatar":       "brand.avatar_url",
    "title":        "brand.name",
    "badge_status": "brand.badge_status"
  },
  "config": {
    "show_close": false
  },
  "layout": {
    "spacing": 4,
    "avatar":       { "size": { "width": 24, "height": 24 } },
    "text":         { "text_style": "body2semibold" },
    "badge":        { "size": { "width": 12, "height": 12 } },
    "close_button": { "size": { "width": 16, "height": 16 } }
  }
}
